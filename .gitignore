# Terraform state
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform backend config (contains sensitive values)
backend.hcl

# Terraform working directories
.terraform/

# Lock files should be committed — do NOT add .terraform.lock.hcl here

# Crash logs
crash.log
crash.*.log

# Sensitive variable files
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Debug logs
terraform-debug.log
